{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C (MSVC)",
            "type": "shell",
            "command": "${workspaceFolder}\\.vscode\\build-msvc.cmd",
            "args": [
                "c",
                "${file}",
                "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build",
            "detail": "Compile the active .c file with MSVC after loading the Visual Studio developer environment."
        },
        {
            "label": "Build C++ (MSVC)",
            "type": "shell",
            "command": "${workspaceFolder}\\.vscode\\build-msvc.cmd",
            "args": [
                "cpp",
                "${file}",
                "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build",
            "detail": "Compile the active .cpp file with MSVC after loading the Visual Studio developer environment."
        }
    ]
}
